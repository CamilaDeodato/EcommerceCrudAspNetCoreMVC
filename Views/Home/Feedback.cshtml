@{
    ViewData["Title"] = "Feedback dos Clientes";
}

<div class="feedback-container">

    <h1 class="feedback-title">O que nossos clientes dizem</h1>

    <div class="feedback-grid">

        <div class="feedback-card">
            <img src="~/images/Heleonora Santana.png" alt="Logo da Loja" class="feedback-img" />
            <p>"Muito boa essa ONG, esses jovens realmente se importam com o meio ambiente!"</p>
            <h4>- HELEONORA SANTANA</h4>
        </div>

        <div class="feedback-card">
            <img src="~/images/Renato da Silva.png" alt="Logo da Loja" class="feedback-img" />
