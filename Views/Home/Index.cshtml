@{
    ViewData["Title"] = "Home Page";
}

<section class="hero">

    <video autoplay muted loop class="hero-video">
        <source src="/videos/videoplayback (1) (1).mp4" type="video/mp4">
    </video>

    <div class="hero-content">

        <h1 class="hero-title">
            Bem-vindo ao <span class="brand"> projeto ultra-marinha </span>
        </h1>

        <p class="hero-subtitle">
            O futuro da vida marinha depende de nós!
        </p>

        <p class="hero-ai-text">
            <span id="typed"></span>
        </p>

        <div class="hero-buttons">
            <a href="/Usuario/Login" class="btn btn-outline-light btn-lg">Login</a>
            <a href="/Usuario/Cadastrar" class="btn btn-outline-light btn-lg">Cadastrar</a>
        </div>

    </div>

</section>

<div id="myPlot" style="width:100%;max-width:900px"></div>

<script>

    const xArray = ["China", "Indonésia", "Filipinas", "Vietnã", "Sri Lanka"];
    const yArray = [27, 10, 6, 6, 5];

    const data = [{
        labels: xArray,
        values: yArray,
        type: "pie",
        hole: .35,
        textinfo: "label+percent",
        hoverinfo: "label+percent+value",
        marker: {
            colors: [
                "#00f7ff",
                "#007bff",
                "#00ff9c",
                "#ff3b3b",
                "#b86bff"
            ]
        }
    }];

    const layout = {
        title: {
            text: "Países com maior taxa de morte de animais marinhos devido a poluição:",
            font: {
                size: 24,
                color: "#ffffff"
            }
        },

        paper_bgcolor: "rgba(0,0,0,0)",
        plot_bgcolor: "rgba(0,0,0,0)",

        font: {
            color: "#ffffff"
        },

        showlegend: true
    };

    const config = {
        responsive: true,
        displayModeBar: true
    };

    Plotly.newPlot("myPlot", data, layout, config);

</script>

