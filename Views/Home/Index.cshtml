@{
    ViewData["Title"] = "Home Page";
}

<section class="hero">

    <video autoplay muted loop class="hero-video">
        <source src="/videos/robot-battle.mp4" type="video/mp4">
    </video>

    <div class="hero-content">

        <h1 class="hero-title">
            Bem-vindo à <span class="brand">RoboForge</span>
        </h1>

        <p class="hero-subtitle">
            O futuro da robótica começa aqui
        </p>

        <p class="hero-ai-text">
            <span id="typed"></span>
        </p>

        <div class="hero-buttons">
            <a href="/Usuario/Login" class="btn btn-outline-light btn-lg">Login</a>
            <a href="/Usuario/Cadastrar" class="btn btn-outline-light btn-lg">Cadastrar</a>
        </div>

    </div>

</section>